# R/Shiny specific
.Rproj.user
.Rhistory
.RData
.Ruserdata
*.Rproj
.httr-oauth
.DS_Store
*.rds
*.RDS

# Shiny
rsconnect/
shinyapps/

# Data files (usually too large for Git)
*.parquet
*.csv
*.xlsx
*.tsv
*.feather
*.arrow

# Logs
*.log
/tmp/

# System
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
.claude/

# Agent/tooling state and Python cache (never commit)
.omc/
__pycache__/
*.pyc

# Outputs (regenerate from code)
plots/
figures/
*.pdf
*.png
*.jpg

# Development specs (already implemented)
*_SPEC*.md
*_COMPACT.md
DE-LIMP_OVERVIEW.md
DE-LIMP_Wiki.html
DIANN_HPC_INTEGRATION_SPEC.md

# SSH keys (never commit private keys)
data/ssh/*
!data/ssh/.gitkeep

# Docker per-user override (generated by launcher)
docker-compose.override.yml

# HPC batch scripts
*.sbatch

# Example/test data directories
Affinisep_vs_evosep_noNorm_xic/
.core_facility_test/
Citations/
Phospho/

# Temp files
files.zip
*.fasta

# Screenshots
Screenshot *.png

# Test fixtures and golden baselines
!tests/fixtures/*.zip
!tests/golden/*.rds
!tests/golden/*.md

# Keep documentation
!CLAUDE.md
!README.md
!README_GITHUB.md
!README_HF.md
!CHANGELOG.md
!USER_GUIDE.md
!HPC_DEPLOYMENT.md
!CORE_FACILITY_PHASE2_SPEC.md
!contaminants/*.fasta

# Private ops docs — kept in ~/Documents/claude_private/ only, never committed
HIVE_CLAUDE_GUIDE.md
